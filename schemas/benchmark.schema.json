{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "benchmark.schema.json",
  "title": "LLM Benchmark Definition",
  "description": "ベンチマーク定義ファイルのスキーマ。モデルへのプロンプトと採点基準を定義する。",
  "type": "object",
  "required": ["benchmark_meta", "domains"],
  "additionalProperties": false,

  "properties": {
    "benchmark_meta": {
      "description": "ベンチマーク全体のメタ情報",
      "type": "object",
      "required": ["title", "version", "total_domains", "total_questions", "scoring_scale"],
      "additionalProperties": false,
      "properties": {
        "title":           { "type": "string", "description": "ベンチマーク名称" },
        "version":         { "type": "string", "description": "バージョン識別子", "examples": ["2.0"] },
        "created":         { "type": "string", "format": "date", "description": "作成日 (YYYY-MM-DD)" },
        "description":     { "type": "string", "description": "ベンチマークの目的・概要説明" },
        "total_domains":   { "type": "integer", "minimum": 1, "description": "ドメイン総数" },
        "total_questions": { "type": "integer", "minimum": 1, "description": "問題総数" },
        "scoring_scale": {
          "description": "スコア体系の定義",
          "type": "object",
          "required": ["max", "levels"],
          "additionalProperties": false,
          "properties": {
            "max":    { "type": "integer", "description": "最高スコア値", "examples": [5] },
            "levels": {
              "type": "array",
              "description": "有効なスコア値一覧（降順）",
              "items": { "type": "integer", "minimum": 0 },
              "examples": [[5, 3, 1, 0]]
            }
          }
        }
      }
    },

    "domains": {
      "description": "評価ドメインの一覧",
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/domain" }
    }
  },

  "$defs": {
    "domain": {
      "description": "評価ドメイン（能力カテゴリ）",
      "type": "object",
      "required": ["id", "label", "questions"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "ドメインの一意識別子 (snake_case)"
        },
        "label":       { "type": "string", "description": "表示名" },
        "color":       { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$", "description": "UI表示用カラーコード (hex)" },
        "difficulty":     { "type": "string", "description": "ドメイン全体の難易度目安", "examples": ["易", "中", "難"] },
        "description":    { "type": "string", "description": "このドメインで評価する能力の説明" },
        "is_new":         { "type": "boolean", "description": "新規追加ドメインのフラグ" },
        "added_version":  { "type": "string", "description": "追加されたバージョン番号" },
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/question" }
        }
      }
    },

    "question": {
      "description": "個別の評価問題",
      "type": "object",
      "required": ["id", "title", "difficulty", "tags", "prompt", "scoring"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "問題の一意識別子 (snake_case)。所属ドメインIDを接頭辞にすること (例: task_decomp_01)"
        },
        "title":       { "type": "string", "description": "問題タイトル" },
        "difficulty": {
          "type": "string",
          "pattern": "^[★☆]{1,5}$",
          "description": "難易度 (★1〜5段階)",
          "examples": ["★★★", "★★★★", "★★★★★"]
        },
        "tags": {
          "type": "array",
          "description": "評価能力を表すキーワードタグ",
          "items": { "type": "string" },
          "minItems": 1
        },
        "input_type":       { "type": "string", "description": "入力データの種別説明 (例: 自然言語ゴール)" },
        "output_type":      { "type": "string", "description": "期待する出力形式の説明 (例: 実行プラン（DAG形式）)" },
        "metric":           { "type": "string", "description": "主要評価指標の説明" },
        "evaluation_focus": { "type": "string", "description": "採点時に特に注目すべき観点" },
        "expected_output":  { "type": "string", "description": "模範回答または期待される出力例" },
        "prompt":      { "type": "string", "minLength": 1, "description": "モデルへ送信するプロンプト本文" },
        "scoring": {
          "description": "採点基準の一覧。有効スコア値ごとに1エントリ必須",
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/scoring_criterion" }
        }
      }
    },

    "scoring_criterion": {
      "description": "1段階分の採点基準",
      "type": "object",
      "required": ["score", "label"],
      "additionalProperties": false,
      "properties": {
        "score": {
          "type": "integer",
          "enum": [0, 1, 3, 5],
          "description": "このラベルに対応するスコア値"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "このスコアを与える条件・基準の説明"
        }
      }
    }
  }
}
