{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "result.schema.json",
  "title": "LLM Benchmark Result",
  "description": "ベンチマーク実行結果ファイルのスキーマ。モデルの回答・採点データを格納する。",
  "type": "object",
  "required": ["meta", "domains"],
  "additionalProperties": false,

  "properties": {
    "meta": {
      "description": "実行条件のメタ情報",
      "type": "object",
      "required": ["benchmark_title", "model", "run_at", "max_tokens", "temperature"],
      "additionalProperties": false,
      "properties": {
        "benchmark_title":   { "type": "string", "description": "ベンチマーク名称" },
        "benchmark_version": { "type": "string", "description": "ベンチマークバージョン" },
        "benchmark_file":    { "type": "string", "description": "使用したベンチマーク定義ファイル名" },
        "model":             { "type": "string", "description": "評価対象モデルのキー/ID" },
        "base_url":          { "type": "string", "format": "uri", "description": "推論エンドポイントのベースURL" },
        "run_at": {
          "type": "string",
          "format": "date-time",
          "description": "実行開始日時 (ISO 8601)"
        },
        "system_prompt":       { "type": "string", "description": "システムプロンプト" },
        "temperature":         { "type": "number", "minimum": 0, "maximum": 2, "description": "サンプリング温度" },
        "max_tokens":          { "type": "integer", "minimum": 1, "description": "最大生成トークン数" },
        "top_p":               { "type": ["number", "null"], "minimum": 0, "maximum": 1, "description": "nucleus sampling 閾値" },
        "top_k":               { "type": ["integer", "null"], "minimum": 0, "description": "top-k サンプリング" },
        "frequency_penalty":   { "type": ["number", "null"], "minimum": -2, "maximum": 2, "description": "頻度ペナルティ" },
        "presence_penalty":    { "type": ["number", "null"], "minimum": -2, "maximum": 2, "description": "存在ペナルティ" },
        "repeat_penalty":      { "type": ["number", "null"], "minimum": 0, "description": "繰り返しペナルティ" },
        "min_p":               { "type": ["number", "null"], "minimum": 0, "maximum": 1, "description": "min-p サンプリング" },
        "seed":                { "type": ["integer", "null"], "description": "乱数シード (-1=ランダム)" },
        "stop":                { "type": ["array", "null"], "items": { "type": "string" }, "description": "停止トークン一覧" },
        "preset_name":         { "type": ["string", "null"], "description": "使用したプリセット名" }
      }
    },

    "domains": {
      "description": "ドメインごとの回答結果一覧",
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/result_domain" }
    }
  },

  "$defs": {
    "result_domain": {
      "description": "1ドメイン分の結果",
      "type": "object",
      "required": ["id", "label", "questions"],
      "additionalProperties": false,
      "properties": {
        "id":    { "type": "string", "pattern": "^[a-z][a-z0-9_]*$", "description": "ドメイン識別子" },
        "label": { "type": "string", "description": "ドメイン表示名" },
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/result_question" }
        }
      }
    },

    "result_question": {
      "description": "1問分の実行結果",
      "type": "object",
      "required": ["id", "title", "difficulty", "tags", "status", "response", "elapsed_sec", "usage", "error", "score", "scoring_criteria", "score_comment"],
      "additionalProperties": false,
      "properties": {
        "id":         { "type": "string", "description": "問題識別子" },
        "title":      { "type": "string", "description": "問題タイトル" },
        "difficulty": { "type": "string", "description": "難易度 (★表記)" },
        "tags":       { "type": "array", "items": { "type": "string" }, "description": "タグ一覧" },

        "status": {
          "type": "string",
          "enum": ["success", "error"],
          "description": "API呼び出しの成否"
        },
        "response": {
          "type": ["string", "null"],
          "description": "モデルの回答テキスト。エラー時は null"
        },
        "elapsed_sec": {
          "type": "number",
          "minimum": 0,
          "description": "回答生成にかかった秒数"
        },
        "usage": {
          "description": "トークン使用量。未取得の場合は空オブジェクト {}",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "prompt_tokens":     { "type": "integer", "minimum": 0 },
            "completion_tokens": { "type": "integer", "minimum": 0 },
            "total_tokens":      { "type": "integer", "minimum": 0 },
            "tokens_per_second": { "type": "number",  "minimum": 0 }
          }
        },
        "error": {
          "type": ["string", "null"],
          "description": "エラーメッセージ。正常終了時は null"
        },

        "score": {
          "type": ["integer", "null"],
          "enum": [0, 1, 3, 5, null],
          "description": "採点結果。未採点は null、採点済みは 0/1/3/5"
        },
        "score_comment": {
          "type": ["string", "null"],
          "description": "採点コメント。採点根拠・判定理由を自由記述する。未記入は null"
        },
        "scoring_criteria": {
          "description": "採点基準一覧（ベンチマーク定義からコピー）",
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/scoring_criterion" }
        }
      }
    },

    "scoring_criterion": {
      "description": "1段階分の採点基準",
      "type": "object",
      "required": ["score", "label"],
      "additionalProperties": false,
      "properties": {
        "score": {
          "type": "integer",
          "enum": [0, 1, 3, 5]
        },
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
